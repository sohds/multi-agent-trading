# ── 필수 ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── 분석 대상 ────────────────────────────────────────────────
TARGET_TICKER=005930
TARGET_NAME=삼성전자
SECTOR_ETF_TICKER=091160          # KODEX 반도체: 091160 / KODEX 2차전지: 305720

# ── 실행 옵션 ────────────────────────────────────────────────
DEBATE_ROUNDS=1                   # 토론 라운드 수 (1 = 단일 패스, 2 = 리버튼 포함)
CLAUDE_MODEL=claude-sonnet-4-6    # 사용할 Claude 모델
SAVE_JSON=true
OUTPUT_DIR=output

# ── 외부 에이전트 연동 ────────────────────────────────────────
USE_MACRO=true                    # false면 macro 에이전트 건너뜀 (API 키 없을 때 유용)
USE_SECTOR=true                   # false면 sector 에이전트 건너뜀
