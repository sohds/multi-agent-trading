# DART Open API 키 (https://opendart.fss.or.kr 에서 발급)
DART_API_KEY=your_dart_api_key_here

# 분석 대상 종목
TARGET_TICKER=005930
TARGET_NAME=삼성전자

# 섹터 ETF 코드
SECTOR_ETF_TICKER=091160

# 네이버 크롤링 설정
NAVER_REQUEST_DELAY=1.0
NAVER_MAX_RETRIES=3
NAVER_TIMEOUT=10

# 결과 저장
OUTPUT_DIR=output
SAVE_JSON=false
LOG_LEVEL=INFO

# KRX 회원 정보 (pykrx 사용 시 필요 — https://www.krx.co.kr 에서 가입)
KRX_ID=your_krx_id_here
KRX_PW=your_krx_password_here
