# ============================================================
# 공통 설정
# ============================================================
OUTPUT_DIR=output
SAVE_JSON=true
LOG_LEVEL=INFO

# ── 분석 대상 종목 ───────────────────────────────────────────
TARGET_TICKER=005930
TARGET_NAME=삼성전자
SECTOR_ETF_TICKER=091160          # KODEX 반도체: 091160 / KODEX 2차전지: 305720

# ============================================================
# API 키
# ============================================================

# Anthropic Claude API (bull-bear 에이전트)
# https://console.anthropic.com 에서 발급
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# 한국은행 ECOS API (macro 에이전트)
# https://ecos.bok.or.kr/api/ 에서 발급
ECOS_API_KEY=your_ecos_api_key_here

# DART Open API (sector 에이전트 — 실적 수집)
# https://opendart.fss.or.kr 에서 발급
DART_API_KEY=your_dart_api_key_here

# KRX 로그인 정보 (pykrx 수급 데이터 수집 시 필요)
# https://www.krx.co.kr 에서 가입
KRX_ID=your_krx_id_here
KRX_PW=your_krx_password_here

# KRX Open API — 파생상품지수 시세정보
KRX_AUTH_KEY=your_krx_auth_key_here

# ============================================================
# bull-bear 실행 옵션
# ============================================================
DEBATE_ROUNDS=1                   # 토론 라운드 수 (1 = 단일 패스, 2 = 반박 포함)
CLAUDE_MODEL=claude-sonnet-4-6    # 사용할 Claude 모델

# 외부 에이전트 연동 (false면 해당 에이전트 건너뜀)
USE_MACRO=true
USE_SECTOR=true

# ============================================================
# sector 크롤링 설정
# ============================================================
NAVER_REQUEST_DELAY=1.0
NAVER_MAX_RETRIES=3
NAVER_TIMEOUT=10
